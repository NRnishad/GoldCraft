{
    "compilerOptions": {
      "strict": true,
      "jsx": "react-jsx",
      "target": "ES2020",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "baseUrl": ".",
      "paths": {
        "@features/*": [
          "src/features/*"
        ],
        "@shared/*": [
          "src/shared/*"
        ]
      }
    }}