{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@entities/*": ["src/entities/*"],
      "@use-cases/*": ["src/use-cases/*"],
      "@adapters/*": ["src/interface-adapters/*"],
      "@drivers/*": ["src/frameworks-and-drivers/*"]
    }
  },
  "include": ["src"]
}